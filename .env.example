# Database
DATABASE_URL=postgresql://tilkural:tilkural_secret@localhost:5432/tilkural

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# Google Gemini API (fallback при rate-limit Groq, либо primary если LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key

# Groq (primary LLM, free tier — console.groq.com/keys)
# Если оба ключа заданы — диспетчер использует Groq, при 429 уходит на Gemini.
# LLM_PROVIDER: groq | gemini | auto (auto = Groq если ключ есть, иначе Gemini)
GROQ_API_KEY=
LLM_PROVIDER=groq
GROQ_MODEL_TEXT=llama-3.3-70b-versatile
GROQ_MODEL_JSON=openai/gpt-oss-120b

# Telegram авто-постинг для опубликованных news/events.
# Бот добавляется админом канала с правом публикации.
# Получить chat_id: написать @userinfobot в канал, или
#   curl https://api.telegram.org/bot$TOKEN/getUpdates
# Если переменные пусты — авто-постинг тихо пропускается.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Двуязычный пост: kk | ru | both. По умолчанию both (два сообщения подряд).
TELEGRAM_POST_LOCALES=both

# App
# Публичный URL сайта (canonical / OG / sitemap / robots / JSON-LD).
# ОБЯЗАТЕЛЬНО выставить в проде — иначе SEO-ссылки покажут localhost/Vercel-URL.
# Примеры:
#   prod:   https://til-kural.kz
#   tunnel: https://<slug>.trycloudflare.com
#   dev:    http://localhost:3015  (дефолт, если переменная не задана)
# Трейлинг-слэш срезается автоматически. На Vercel без этой переменной fallback
# на https://$VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3015
NEXT_PUBLIC_DEFAULT_LOCALE=kk

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Admin dev bypass
# DEV ONLY: открывает /[locale]/admin и /api/admin/* без логина.
# Работает ТОЛЬКО при NODE_ENV !== 'production' — на проде значение игнорируется
# (и middleware, и requireAdminApi форсированно требуют валидный JWT).
# Для prod НЕ устанавливать переменную или явно выставить DEV_ADMIN_BYPASS=0.
# Безопасность: CF-tunnel/прод публичны — иначе любой в интернете получил бы админку.
DEV_ADMIN_BYPASS=1

# Первичный admin-юзер
# Используются:
#   1) scripts/seed-postgres.mjs — создаёт admin, если в таблице users нет ни одного с role='admin'.
#   2) scripts/create-admin.mjs  — standalone-скрипт для ручного создания/сброса admin'а на проде.
# TIL_ADMIN_PASSWORD должен быть минимум 8 символов. После первого входа СРАЗУ
# поменяйте пароль через /admin/users → «Сбросить пароль».
TIL_ADMIN_EMAIL=admin@til-kural.kz
TIL_ADMIN_PASSWORD=ChangeMe2026!

# Cron secret для POST /api/cron/publish-scheduled.
# Передаётся либо как `Authorization: Bearer $CRON_SECRET`, либо как `?token=...`.
# Берите что-то типа `openssl rand -hex 32`. В проде обязателен — без него
# endpoint возвращает 401 на любой запрос.
CRON_SECRET=change-me-32-random-bytes

# AI USD-cap (поверх free-tier RPM/RPD/TPM guard в src/lib/ai-quota.ts).
# Block at 90% of cap (USD_SAFETY_RATIO в коде). Daily resets at 00:00 UTC.
# Total resets only manually (поднять CAP_TOTAL или сдвинуть PERIOD_START).
#
# При смене бюджета — обновить и в Cloud Console budget alert (sum по всем
# проектам должен быть ≤ Google account-level budget).
AI_USD_CAP_DAILY=0.50
AI_USD_CAP_TOTAL=4.00
AI_USD_CAP_PERIOD_START=2026-04-30
