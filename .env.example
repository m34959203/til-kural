# Database
DATABASE_URL=postgresql://tilkural:tilkural_secret@localhost:5432/tilkural

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# App
# Публичный URL сайта (canonical / OG / sitemap / robots / JSON-LD).
# ОБЯЗАТЕЛЬНО выставить в проде — иначе SEO-ссылки покажут localhost/Vercel-URL.
# Примеры:
#   prod:   https://til-kural.kz
#   tunnel: https://<slug>.trycloudflare.com
#   dev:    http://localhost:3015  (дефолт, если переменная не задана)
# Трейлинг-слэш срезается автоматически. На Vercel без этой переменной fallback
# на https://$VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3015
NEXT_PUBLIC_DEFAULT_LOCALE=kk

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Admin dev bypass
# DEV ONLY: открывает /[locale]/admin и /api/admin/* без логина.
# Работает ТОЛЬКО при NODE_ENV !== 'production' — на проде значение игнорируется
# (и middleware, и requireAdminApi форсированно требуют валидный JWT).
# Для prod НЕ устанавливать переменную или явно выставить DEV_ADMIN_BYPASS=0.
# Безопасность: CF-tunnel/прод публичны — иначе любой в интернете получил бы админку.
DEV_ADMIN_BYPASS=1
